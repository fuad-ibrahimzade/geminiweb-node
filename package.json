{
  "name": "gemini-playwright-server",
  "version": "1.0.0",
  "description": "Node.js project with Playwright-based Gemini browser automation and OpenAI-compatible API server",
  "main": "dist/index.js",
  "bin": {
    "gemini-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "login": "tsx src/index.ts login",
