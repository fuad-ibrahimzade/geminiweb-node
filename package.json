  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
